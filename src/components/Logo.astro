---
interface Props {
  compact?: boolean;
  inverse?: boolean;
}
const { compact = false, inverse = false } = Astro.props;
import { withBase } from '../data/site';
---

<a class:list={['brand', { compact, inverse }]} href={withBase('/')} aria-label="UNNE Ciencias Neurológicas, ir al inicio">
  <img
    class="brand-logo"
    src={withBase(inverse ? '/images/unne-logo-white.png' : '/images/unne-logo.png')}
    alt=""
    width="2623"
    height="900"
    decoding="async"
  />
</a>
