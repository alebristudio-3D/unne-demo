---
import Icon from './Icon.astro';
import { withBase } from '../data/site';

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  compact?: boolean;
  art?: 'brain' | 'sleep' | 'signal' | 'care';
}

const {
  eyebrow,
  title,
  text,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  compact = false,
  art = 'signal'
} = Astro.props;
---

<section class:list={['hero', { 'hero-compact': compact }]}>
  <div class="container hero-grid">
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="hero-text">{text}</p>
      {(primaryLabel || secondaryLabel) && (
        <div class="button-row">
          {primaryLabel && primaryHref && (
            <a class="button button-primary" href={withBase(primaryHref)} data-track="request_appointment" data-location="hero">
              {primaryLabel}<Icon name="arrow" size={18} />
            </a>
          )}
          {secondaryLabel && secondaryHref && (
            <a class="button button-secondary" href={withBase(secondaryHref)}>{secondaryLabel}</a>
          )}
        </div>
      )}
    </div>
    <div class:list={['hero-art', `art-${art}`]} aria-hidden="true">
      <div class="brand-curve curve-one"></div>
      <div class="brand-curve curve-two"></div>
      <div class="art-orbit orbit-one"></div>
      <div class="art-orbit orbit-two"></div>
      <div class="art-core">
        <img src={withBase('/images/unne-symbol.png')} alt="" width="420" height="420" />
      </div>
      <div class="signal-line"></div>
      <span class="art-label"><Icon name={art === 'sleep' ? 'moon' : 'brain'} size={15} /> Ciencia precisa</span>
      <span class="art-label label-secondary"><Icon name="heart" size={15} /> Atención humana</span>
    </div>
  </div>
</section>
