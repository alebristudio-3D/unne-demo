---
import { icons, type IconName } from '../data/icons';

interface Props {
  name: IconName;
  size?: number;
  label?: string;
}

const { name, size = 24, label } = Astro.props;
---

<svg
  class="icon"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={label ? undefined : 'true'}
  aria-label={label}
  set:html={icons[name]}
/>
