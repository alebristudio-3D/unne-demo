---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import PendingPanel from '../../components/PendingPanel.astro';
import CtaBand from '../../components/CtaBand.astro';

const doctors = await getCollection('doctors');
const published = doctors.filter((doctor) => doctor.data.status === 'published');
const drafts = doctors.filter((doctor) => doctor.data.status === 'draft');
---

<BaseLayout
  title="Especialistas"
  description="Conoce la estructura de los perfiles médicos de UNNE Puebla. Credenciales y disponibilidad se publican únicamente después de su verificación."
  pageType="doctor-index"
>
  <Hero
    eyebrow="Equipo médico"
    title="Especialistas presentados con rigor"
    text="Cada perfil está diseñado para mostrar formación, cédulas, certificaciones y áreas de atención sólo cuando hayan sido verificadas directamente."
    primaryLabel="Solicitar valoración"
    primaryHref="/agendar/"
    compact
    art="care"
  />

  <section class="section">
    <div class="container">
      {published.length > 0 ? (
        <div class="grid-3">
          {published.map((doctor) => (
            <article class="card">
              <div class="placeholder-frame doctor-frame">
                <div><Icon name="heart" size={42} /><span>Fotografía profesional</span></div>
              </div>
              <h2>{doctor.data.name}</h2>
              {doctor.data.role && <p>{doctor.data.role}</p>}
              <a class="text-link" href={`/especialistas/${doctor.id}/`}>Ver perfil <Icon name="arrow" size={17} /></a>
            </article>
          ))}
        </div>
      ) : (
        <div class="content-split">
          <div>
            <p class="eyebrow">Validación en curso</p>
            <h2>Los perfiles aún no están listos para publicación</h2>
            <p>El sitio anterior contiene información valiosa, pero presenta datos que pueden haber cambiado. Por responsabilidad profesional, la versión pública no muestra cédulas, certificaciones ni disponibilidad sin aprobación.</p>
          </div>
          <PendingPanel
            title={`${drafts.length} perfiles preparados para revisión`}
            text="Las rutas individuales existen en modo vista previa y permanecen bloqueadas para buscadores."
          />
        </div>
      )}
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <header class="section-heading align-center">
        <p class="eyebrow">Qué tendrá cada perfil</p>
        <h2>Información útil y verificable</h2>
      </header>
      <div class="grid-4">
        <div class="feature-card"><div class="card-icon"><Icon name="document" /></div><h3>Credenciales</h3><p>Cédulas y certificaciones vigentes.</p></div>
        <div class="feature-card"><div class="card-icon"><Icon name="brain" /></div><h3>Especialidad</h3><p>Áreas clínicas y subespecialidades.</p></div>
        <div class="feature-card"><div class="card-icon"><Icon name="heart" /></div><h3>Atención</h3><p>Edades, padecimientos y sedes confirmadas.</p></div>
        <div class="feature-card"><div class="card-icon"><Icon name="calendar" /></div><h3>Disponibilidad</h3><p>Proceso claro para solicitar una cita.</p></div>
      </div>
    </div>
  </section>

  <CtaBand title="¿Necesitas una valoración neurológica?" text="Solicita orientación. El perfil y disponibilidad del especialista se confirmarán por un canal oficial." />
</BaseLayout>
