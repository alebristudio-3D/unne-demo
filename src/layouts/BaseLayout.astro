---
import '@fontsource-variable/manrope';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { clinicConfig, isPreview, withBase } from '../data/site';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  pageType?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image = '/images/og-default.png',
  noindex = false,
  pageType = 'page',
  schema
} = Astro.props;

const canonical = new URL(withBase(Astro.url.pathname), Astro.site);
const robots = noindex || isPreview ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';
const fullTitle = title === 'Inicio'
  ? `${clinicConfig.name} | Neurología y neurofisiología en Puebla`
  : `${title} | ${clinicConfig.name} Puebla`;

const baseSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: clinicConfig.name,
  alternateName: clinicConfig.descriptor,
  url: new URL(withBase('/'), Astro.site).toString(),
  medicalSpecialty: ['Neurology', 'SleepMedicine'],
  description
};
const schemas = schema ? [baseSchema, ...(Array.isArray(schema) ? schema : [schema])] : [baseSchema];
---

<!doctype html>
<html lang="es-MX" data-site-mode={isPreview ? 'preview' : 'production'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content={clinicConfig.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(withBase(image), Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#1c5476" />
    <link rel="icon" href={withBase('/images/unne-symbol.png')} type="image/png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemas)} />
  </head>
  <body data-page-type={pageType}>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    {isPreview && (
      <div class="preview-banner" role="status">
        Vista previa: datos de contacto, perfiles y textos legales aún requieren aprobación.
      </div>
    )}
    <Header currentPath={Astro.url.pathname} />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/site';
    </script>
  </body>
</html>
