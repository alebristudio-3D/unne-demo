# preview bloquea la indexación y permite revisar contenido pendiente.
# production exige los campos críticos antes del build.
SITE_MODE=preview
PUBLIC_SITE_URL=https://www.unnepuebla.mx
PUBLIC_BASE_PATH=/

# Endpoint HTTPS que acepta el contrato descrito en README.md.
PUBLIC_FORM_ENDPOINT=

# Proveedor opcional. Valores soportados: none, gtag, dataLayer.
PUBLIC_ANALYTICS_PROVIDER=none
PUBLIC_GA_ID=

# Datos aprobados para publicación. No usar valores de prueba.
PUBLIC_CLINIC_PHONE=
PUBLIC_CLINIC_WHATSAPP=
PUBLIC_CLINIC_EMAIL=
PUBLIC_CLINIC_ADDRESS=
PUBLIC_CLINIC_MAP_URL=
PUBLIC_CLINIC_WEEKDAY_HOURS=
PUBLIC_CLINIC_SATURDAY_HOURS=

# Confirmaciones de contenido y cumplimiento.
PUBLIC_CONTACT_APPROVED=false
PUBLIC_DOCTOR_PROFILES_APPROVED=false
PUBLIC_PRIVACY_NOTICE_APPROVED=false
